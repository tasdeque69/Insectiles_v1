{
  "name": "pinik-pipra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --import ./tests/setup.ts --test tests/*.test.ts",
    "test:watch": "node --watch --import tsx --import ./tests/setup.ts --test tests/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "e2e:install": "npx playwright install --with-deps",
    "e2e:preflight": "node ./scripts/e2e-preflight.mjs",
    "test:e2e:smoke": "npm run e2e:preflight && playwright test --project=chromium",
    "perf:smoke": "node --import tsx ./scripts/perf-smoke.mjs",
    "test:coverage": "node --experimental-test-coverage --import tsx --import ./tests/setup.ts --test tests/*.test.ts",
    "audit:branches": "node scripts/branch-pr-audit.mjs",
    "audit:branches:check": "node scripts/branch-pr-audit.mjs --check",
    "audit:branches:verify": "npm run audit:branches && npm run audit:branches:validate",
    "audit:branches:validate": "node scripts/branch-pr-audit.mjs --validate"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "@vitejs/plugin-react": "^5.0.4"
  }
}
